# =====================================================================
# 운영자 전용 부트스트랩 환경변수
#   - 코드/마이그레이션에 박지 않고 여기서 관리.
#   - 본 파일을 .env 로 복사 (`cp .env.example .env`) 후 값 채움.
#   - .env 는 .gitignore 처리됨 (.env.*) — 절대 commit 금지.
# =====================================================================

# 초기 admin 으로 승격할 이메일.
# Supabase Dashboard → Auth → Users 에서 이 이메일로 사용자 생성한 뒤,
# scripts/print_bootstrap_admin_sql.sh 출력을 SQL Editor 에 붙여넣어 실행.
ADMIN_EMAIL=admin@example.com
