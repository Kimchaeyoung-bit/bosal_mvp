# MVP 테스트 계정 (개발용, DATA_SOURCE=mock 일 때만 사용됨)
TEST_USER_USERNAME=a
TEST_USER_PASSWORD=1234
TEST_BOSAL_USERNAME=b
TEST_BOSAL_PASSWORD=1234

# Supabase
# Project Settings → API 에서 복사
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Sentry 에러 추적 (선택). 미설정 시 Sentry 비활성.
# Project Settings → SDK Setup 에서 복사
SENTRY_DSN=

# 데이터 소스 선택: mock | supabase
# - mock: lib/data/mock/ 로컬 데이터, 오프라인 개발/QA용
# - supabase: 원격 DB. 배포 기본값
DATA_SOURCE=supabase
